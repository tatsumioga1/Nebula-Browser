<Window
    x:Class="Nebula.BrowserWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:local="using:Nebula.Controls">

    <Grid
        x:Name="RootGrid"
        PointerMoved="RootGrid_PointerMoved">

        <controls:WebView2
            x:Name="BrowserView" />

        <Border
            x:Name="Dock"
            Opacity="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="20,0,20,40"
            Padding="18"
            CornerRadius="36"
            BorderThickness="1"
            BorderBrush="#55FFFFFF"
            Background="#CC0F0F0F">

            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>

            <Border.RenderTransform>
                <TranslateTransform
                    x:Name="DockTransform"
                    Y="40"/>
            </Border.RenderTransform>

            <Grid>

                <Border
                    BorderBrush="#15FFFFFF"
                    BorderThickness="1"
                    CornerRadius="36"
                    Margin="1"/>

                <Border
                    Background="#18FFFFFF"
                    CornerRadius="36"/>

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Navigation -->

                    <StackPanel
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="8">

                        <local:DockButton
                            Glyph="&#xE72B;"
                            Click="Back_Click"/>

                        <local:DockButton
                            Glyph="&#xE72A;"
                            Click="Forward_Click"/>

                        <local:DockButton
                            Glyph="&#xE72C;"
                            Click="Refresh_Click"/>

                    </StackPanel>

                    <!-- Arc Omnibox -->

                    <Border
                        x:Name="OmniboxBorder"
                        Grid.Column="2"
                        Width="160"
                        Background="#20FFFFFF"
                        CornerRadius="22"
                        Padding="18,8"
                        HorizontalAlignment="Center"
                        MinWidth="160">

                        <Grid>

                            <Border
                                x:Name="DisplayMode"
                                Background="Transparent"
                                Tapped="DisplayMode_Tapped">

                                <Grid
                                    IsHitTestVisible="False">

                                    <StackPanel
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8">

                                        <Image
                                            x:Name="SiteIcon"
                                            Width="16"
                                            Height="16"
                                            Stretch="Uniform"
                                            VerticalAlignment="Center"/>

                                        <TextBlock
                                            x:Name="SiteTitle"
                                            Text="Loading..."
                                            Foreground="White"
                                            FontWeight="SemiBold"
                                            VerticalAlignment="Center"/>

                                    </StackPanel>

                                </Grid>

                            </Border>

                            <TextBox
                                x:Name="Omnibox"
                                Visibility="Collapsed"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="White"
                                HorizontalAlignment="Stretch"
                                TextAlignment="Center"
                                PlaceholderText="Search or enter URL"
                                GotFocus="Omnibox_GotFocus"
                                LostFocus="Omnibox_LostFocus"
                                KeyDown="Omnibox_KeyDown"/>

                        </Grid>

                    </Border>

                    <!-- Utilities -->

                    <StackPanel
                        Grid.Column="4"
                        Orientation="Horizontal"
                        Spacing="8">

                        <local:DockButton
                            Glyph="&#xE80F;"
                            Click="Home_Click"/>

                        <local:DockButton
                            Glyph="&#xE8C8;"
                            Click="CopyUrl_Click"/>

                        <local:DockButton
                            Glyph="&#xE740;"
                            Click="Fullscreen_Click"/>

                        <local:DockButton
                            Glyph="&#xEA18;"/>

                    </StackPanel>

                </Grid>

            </Grid>

        </Border>

    </Grid>

</Window>