<UserControl
    x:Class="Nebula.Controls.DockButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border x:ConnectionId='2'
        x:Name="ButtonSurface"
        Width="44"
        Height="44"
        CornerRadius="22"
        Background="#12FFFFFF"
        RenderTransformOrigin="0.5,0.5"
                                     
                                                     
                                                   
                                                     
                                                       >

        <Border.RenderTransform>

            <ScaleTransform x:ConnectionId='3'
                x:Name="ScaleTransform"
                ScaleX="1"
                ScaleY="1"/>

        </Border.RenderTransform>

        <Grid>

            <FontIcon x:ConnectionId='4'
                x:Name="Icon"
                FontSize="18"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>

        </Grid>

    </Border>

</UserControl>

