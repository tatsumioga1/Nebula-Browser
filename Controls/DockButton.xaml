<UserControl
    x:Class="Nebula.Controls.DockButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        x:Name="ButtonSurface"
        Width="44"
        Height="44"
        CornerRadius="22"
        Background="#12FFFFFF"
        RenderTransformOrigin="0.5,0.5"
        Tapped="ButtonSurface_Tapped"
        PointerEntered="ButtonSurface_PointerEntered"
        PointerExited="ButtonSurface_PointerExited"
        PointerPressed="ButtonSurface_PointerPressed"
        PointerReleased="ButtonSurface_PointerReleased">

        <Border.RenderTransform>

            <ScaleTransform
                x:Name="ScaleTransform"
                ScaleX="1"
                ScaleY="1"/>

        </Border.RenderTransform>

        <Grid>

            <FontIcon
                x:Name="Icon"
                FontSize="18"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>

        </Grid>

    </Border>

</UserControl>